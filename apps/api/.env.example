# Local dev with `docker compose up -d` (Postgres on host port 5433, Redis on 6379)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/keep-it-short
REDIS_PASSWORD=redis_secure_password
REDIS_URL=redis://:redis_secure_password@localhost:6379

# Required in production (including `docker compose --profile app`). Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated; include http://localhost when using the Docker web service on port 80
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost